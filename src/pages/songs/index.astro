---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const songs = (await getCollection('songs', (s) => import.meta.env.DEV || !s.data.draft)).sort(
  (a, b) => a.data.order - b.data.order || a.data.title.localeCompare(b.data.title)
);
const releases = await getCollection('releases');
const releaseTitle = (slug?: string) => releases.find((r) => r.id === slug)?.data.title;
---

<Base title="Behind the Songs">
  <section class="container">
    <h1 style="font-size: clamp(2.2rem, 5vw, 3.2rem);">Behind the Songs</h1>
    <p class="muted" style="max-width: 56ch;">
      The stories under the songs — why I wrote them, what they mean, and what was happening when
      they showed up.
    </p>
  </section>

  <section class="container" style="padding-top: 0; padding-bottom: 4.5rem;">
    {songs.length > 0 ? (
      <div style="display: grid; gap: 1rem; max-width: 680px;">
        {songs.map((song) => (
          <a href={`/songs/${song.id}/`} class="card" style="display: block;">
            <h3 style="margin-bottom: 0.25rem;">{song.data.title}</h3>
            {releaseTitle(song.data.release) && (
              <p class="muted small" style="margin-bottom: 0.4rem;">
                from {releaseTitle(song.data.release)}
              </p>
            )}
            {song.data.excerpt && <p class="muted" style="margin: 0;">{song.data.excerpt}</p>}
          </a>
        ))}
      </div>
    ) : (
      <div class="empty-state" style="max-width: 680px;">
        <p style="margin: 0;">
          The first stories are being written. Until then, the songs can speak for themselves —
          <a href="/music/">go listen</a>.
        </p>
      </div>
    )}
  </section>
</Base>
