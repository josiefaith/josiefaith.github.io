---
import '@fontsource-variable/playfair-display';
import '@fontsource-variable/lora';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import IrisMark from '../components/IrisMark.astro';
import artist from '../data/artist.json';

interface Props {
  title?: string;
  description?: string;
  drawIris?: boolean; // homepage: the brand iris draws itself in
}
const {
  title,
  description = `${artist.name} — music, the stories behind the songs, and shows.`,
  drawIris = false,
} = Astro.props;
const pageTitle = title ? `${title} · ${artist.name}` : `${artist.name} — ${artist.tagline}`;

const nav = [
  { href: '/music/', label: 'Music' },
  { href: '/songs/', label: 'Behind the Songs' },
  { href: '/shows/', label: 'Shows' },
  { href: '/about/', label: 'About' },
];
const path = Astro.url.pathname;
const isActive = (href: string) => path === href || path === href.replace(/\/$/, '') || path.startsWith(href);

const social = [
  ['Spotify', artist.links.spotify],
  ['Apple Music', artist.links.apple],
  ['YouTube', artist.links.youtube],
  ['Instagram', artist.links.instagram],
  ['TikTok', artist.links.tiktok],
].filter(([, url]) => url);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <ClientRouter />
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a href="/" class="brand">
          <IrisMark size={22} draw={drawIris} />
          <span>{artist.name}</span>
        </a>
        <nav class="site-nav" aria-label="Main">
          {nav.map((item) => (
            <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <div>
          <span>{artist.name}</span>
          <span class="muted"> · {artist.location}</span>
        </div>
        <div class="platforms">
          {social.map(([label, url]) => (
            <a href={url} target="_blank" rel="noopener">{label}</a>
          ))}
          <a href={`mailto:${artist.email}`}>Contact</a>
        </div>
      </div>
    </footer>

    <script>
      // Gentle scroll reveals; skipped entirely for reduced-motion users.
      // astro:page-load fires on first load and after every ClientRouter swap.
      function initReveals() {
        if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        const els = Array.from(document.querySelectorAll('main section, main article'));
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('in');
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.08 }
        );
        els.forEach((el) => {
          el.classList.add('reveal');
          io.observe(el);
        });
        // Safety net: if observer callbacks never deliver (embedded/background
        // views), nothing may stay hidden — reveal everything after 1s.
        setTimeout(() => els.forEach((el) => el.classList.add('in')), 1000);
      }
      document.addEventListener('astro:page-load', initReveals);
    </script>
  </body>
</html>
