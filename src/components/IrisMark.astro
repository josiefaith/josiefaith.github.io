---
// The iris — Josie's flower. A single-stroke line drawing used as the
// site's quiet recurring mark (header, dividers, placeholders, favicon).
// With `draw`, the iris draws itself in: stem first, from the ground up.
interface Props {
  size?: number;
  class?: string;
  draw?: boolean;
}
const { size = 26, class: className, draw = false } = Astro.props;
const cls = [className, draw && 'iris-draw'].filter(Boolean).join(' ') || undefined;
---

<svg
  viewBox="0 0 64 84"
  width={size}
  height={Math.round((size * 84) / 64)}
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class={cls}
  aria-hidden="true"
>
  <g stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
    <path pathLength="1" d="M32 82 C32 66 32 54 32 40" />
    <path pathLength="1" d="M32 70 C23 66 17 57 18 45 C27 50 31 58 32 66" />
    <path pathLength="1" d="M32 40 C26.5 32 26.5 17 32 8 C37.5 17 37.5 32 32 40 Z" />
    <path pathLength="1" d="M32 40 C24 35 19 26 21 16 C29 21 32.5 30 32 40" />
    <path pathLength="1" d="M32 40 C40 35 45 26 43 16 C35 21 31.5 30 32 40" />
    <path pathLength="1" d="M32 40 C23 39 13 43 10 53 C19 55 28 49 32 40" />
    <path pathLength="1" d="M32 40 C41 39 51 43 54 53 C45 55 36 49 32 40" />
  </g>
</svg>
