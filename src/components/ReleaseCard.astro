---
import type { CollectionEntry } from 'astro:content';
import Art from './Art.astro';

interface Props {
  release: CollectionEntry<'releases'>;
}
const { release } = Astro.props;
const { title, type, date, art, links } = release.data;
const year = date?.getFullYear();
const platformLinks = [
  ['Spotify', links.spotify],
  ['Apple Music', links.apple],
  ['YouTube', links.youtube],
].filter(([, url]) => url);
---

<div class="card">
  <Art src={art ? `/art/${art}` : null} alt={`${title} artwork`} placeholderSize={44} />
  <h3 style="margin-top: 1rem;">{title}</h3>
  <p class="muted small" style="margin-bottom: 0.6rem;">
    {type === 'single' ? 'Single' : type.toUpperCase() === 'EP' ? 'EP' : 'Album'}{year && ` · ${year}`}
  </p>
  <div class="platforms">
    {platformLinks.map(([label, url]) => (
      <a href={url} target="_blank" rel="noopener">{label}</a>
    ))}
  </div>
</div>
